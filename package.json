{
  "name": "docker-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Docker container file browser + embedded console (local Docker CLI)",
  "author": "tiger liu (TigerClaw series / TigerClaw 系列)",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "build": "vite build",
    "start": "node server/standalone.mjs",
    "bundle": "node scripts/bundle.mjs",
    "pack:win": "npm run build && npm run bundle && electron-builder --win",
    "pack:server": "npm run build && npm run bundle && pkg build/docker-manager.cjs -c package.json -t node18-win-x64 -o release/docker-manager-server.exe -C GZip"
  },
  "pkg": {
    "assets": ["dist/**/*"]
  },
  "build": {
    "appId": "com.finastar.tigerclawdockermanager",
    "productName": "TigerClawDockerManager",
    "directories": {
      "output": "release",
      "buildResources": "build-res"
    },
    "icon": "build-res/icon.png",
    "files": [
      "dist/**/*",
      "build/docker-manager.cjs",
      "electron/main.cjs",
      "electron/icon.png",
      "electron/splash.html",
      "server/load-config.mjs",
      "node_modules/yaml/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "pkg": "^5.8.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "wait-on": "^8.0.1"
  }
}
